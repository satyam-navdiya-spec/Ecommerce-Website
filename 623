<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Food Restaurant</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#111;
    color:#fff;
}

/* Header */
header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 60px;
    background:#000;
    position:fixed;
    width:100%;
    top:0;
}

.logo{
    font-size:30px;
    font-weight:bold;
    color:orange;
}

nav a{
    color:#fff;
    text-decoration:none;
    margin-left:20px;
    transition:.3s;
}

nav a:hover{
    color:orange;
}

/* Hero Section */
.hero{
    height:100vh;
    background:url("https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1600") center/cover;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero-content{
    animation:fadeIn 2s;
}

.hero h1{
    font-size:60px;
}

.hero p{
    margin:20px 0;
    font-size:22px;
}

button{
    padding:15px 35px;
    border:none;
    background:orange;
    border-radius:30px;
    font-size:18px;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    background:#fff;
    transform:scale(1.1);
}

/* Menu */
.menu{
    padding:80px 50px;
    text-align:center;
}

.menu h2{
    color:orange;
    margin-bottom:30px;
}

.cards{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:25px;
}

.card{
    width:280px;
    background:#222;
    border-radius:15px;
    overflow:hidden;
    transition:.5s;
}

.card:hover{
    transform:translateY(-10px);
    box-shadow:0 10px 20px orange;
}

.card img{
    width:100%;
    height:220px;
    object-fit:cover;
}

.card h3{
    margin:15px;
}

.card p{
    color:orange;
    margin-bottom:20px;
}

/* Facilities */
.facility{
    padding:80px 50px;
    background:#1a1a1a;
    text-align:center;
}

.facility h2{
    color:orange;
    margin-bottom:30px;
}

.features{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
}

.features div{
    background:#333;
    padding:25px;
    border-radius:10px;
    transition:.3s;
}

.features div:hover{
    background:orange;
    color:#000;
    transform:scale(1.05);
}

/* Footer */
footer{
    background:#000;
    text-align:center;
    padding:20px;
}

/* Animation */
@keyframes fadeIn{
    from{
        opacity:0;
        transform:translateY(-40px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

/* Responsive */
@media(max-width:768px){
    header{
        flex-direction:column;
    }

    .hero h1{
        font-size:40px;
    }
}
</style>

</head>
<body>

<header>
    <div class="logo">🍴 Foodies</div>

    <nav>
        <a href="#">Home</a>
        <a href="#">Menu</a>
        <a href="#">Gallery</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <div class="hero-content">
        <h1>Delicious Food For Everyone</h1>
        <p>Fresh • Healthy • Tasty</p>
        <button>Order Now</button>
    </div>
</section>

<section class="menu">
    <h2>Popular Dishes</h2>

    <div class="cards">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=500">
            <h3>Pizza</h3>
            <p>$12.99</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=500">
            <h3>Burger</h3>
            <p>$9.99</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1621996346565-e3dbc646d9a9?w=500">
            <h3>Pasta</h3>
            <p>$11.99</p>
        </div>

    </div>
</section>

<section class="facility">

<h2>Our Facilities</h2>

<div class="features">
<div>🚚 Fast Delivery</div>
<div>👨‍🍳 Expert Chefs</div>
<div>🌿 Fresh Ingredients</div>
<div>📶 Free Wi-Fi</div>
<div>🎵 Live Music</div>
<div>🚗 Free Parking</div>
</div>

</section>

<footer>
<h3>© 2026 Foodies Restaurant | All Rights Reserved</h3>
</footer>

</body>
</html>
