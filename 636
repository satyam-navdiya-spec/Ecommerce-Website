<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Craving Bites | Hot & Fresh Fast Food</title>
    <style>
        /* --- Base & Reset Styles --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --primary: #ff5e00;
            --primary-hover: #e05300;
            --secondary: #ffc107;
            --bg-dark: #121212;
            --bg-light: #1a1a1a;
            --bg-card: #242424;
            --text-light: #ffffff;
            --text-muted: #a0a0a0;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            line-height: 1.6;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 0;
        }

        .btn {
            display: inline-block;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s ease;
            border: none;
        }

        .btn-primary {
            background-color: var(--primary);
            color: #fff;
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-light);
            border: 2px solid var(--text-light);
        }

        .btn-secondary:hover {
            background-color: var(--text-light);
            color: var(--bg-dark);
        }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 40px;
            position: relative;
        }

        .section-title span {
            color: var(--primary);
        }

        /* --- 1. Header Navigation --- */
        header {
            background-color: rgba(18, 18, 18, 0.95);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid #2d2d2d;
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a:hover {
            color: var(--primary);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .cart-icon {
            font-size: 1.2rem;
            cursor: pointer;
        }

        /* --- 2. Hero Section --- */
        .hero {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.8)), 
                        url('https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=1500&auto=format&fit=crop') no-repeat center center/cover;
            height: 80vh;
            display: flex;
            align-items: center;
            text-align: center;
        }

        .hero-content {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-muted);
            margin-bottom: 40px;
        }

        .hero-btns {
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        /* --- 3. Quick Categories --- */
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            text-align: center;
        }

        .category-card {
            background-color: var(--bg-card);
            padding: 30px;
            border-radius: 12px;
            transition: transform 0.3s ease, border 0.3s ease;
            border: 1px solid transparent;
            cursor: pointer;
        }

        .category-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
        }

        .category-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        .category-card h3 {
            font-size: 1.2rem;
        }

        /* --- 4. Today's Special Offers --- */
        .offers {
            background-color: var(--bg-light);
        }

        .offers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 30px;
        }

        .offer-card {
            background: linear-gradient(135deg, #2c1a10 0%, var(--bg-card) 100%);
            border-left: 5px solid var(--primary);
            padding: 40px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .offer-tag {
            background-color: var(--primary);
            color: white;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
            width: fit-content;
            margin-bottom: 15px;
        }

        .offer-card h3 {
            font-size: 1.8rem;
            margin-bottom: 10px;
        }

        .offer-card p {
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        .offer-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }

        .price {
            font-size: 1.5rem;
            font-weight: bold;
        }

        .old-price {
            text-decoration: line-through;
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-right: 10px;
        }

        /* --- 5. Our Fan Favorites --- */
        .favorites-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .product-card {
            background-color: var(--bg-card);
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease;
        }

        .product-card:hover {
            transform: translateY(-5px);
        }

        .product-img {
            height: 220px;
            background-size: cover;
            background-position: center;
        }

        .product-info {
            padding: 25px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-rating {
            color: var(--secondary);
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .product-rating span {
            color: var(--text-muted);
        }

        .product-info h3 {
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .product-info p {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 20px;
            flex-grow: 1;
        }

        .product-action {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* --- 6. Why Choose Us --- */
        .why-us {
            background-color: var(--bg-light);
        }

        .props-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            text-align: center;
        }

        .prop-card {
            padding: 20px;
        }

        .prop-icon {
            font-size: 3.5rem;
            margin-bottom: 15px;
        }

        .prop-card h3 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .prop-card p {
            color: var(--text-muted);
        }

        /* --- 7. Customer Reviews --- */
        .reviews {
            text-align: center;
        }

        .testimonial-container {
            max-width: 700px;
            margin: 0 auto;
            background-color: var(--bg-card);
            padding: 50px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .testimonial-text {
            font-size: 1.25rem;
            font-style: italic;
            margin-bottom: 25px;
        }

        .testimonial-author {
            font-weight: bold;
            color: var(--primary);
        }

        .stars {
            color: var(--secondary);
            margin-top: 5px;
        }

        /* --- 8. Footer --- */
        footer {
            background-color: #0b0b0b;
            padding: 60px 0 20px 0;
            border-top: 1px solid #2d2d2d;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-col h4 {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: var(--text-light);
        }

        .footer-col ul li {
            margin-bottom: 12px;
        }

        .footer-col ul li a {
            color: var(--text-muted);
            transition: color 0.3s;
        }

        .footer-col ul li a:hover {
            color: var(--primary);
        }

        .social-icons {
            display: flex;
            gap: 15px;
            font-size: 1.2rem;
        }

        .newsletter-form {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .newsletter-form input {
            padding: 10px 15px;
            border-radius: 6px;
            border: 1px solid #333;
            background-color: var(--bg-dark);
            color: white;
            flex-grow: 1;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid #2d2d2d;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* --- Responsive Queries --- */
        @media (max-width: 768px) {
            .nav-links { display: none; }
            .hero h1 { font-size: 2.5rem; }
            .offers-grid { grid-template-columns: 1fr; }
            .testimonial-container { padding: 30px; }
        }
    </style>
</head>
<body>

    <!-- 1. Header (Navigation Bar) -->
    <header>
        <div class="nav-container">
            <a href="#" class="logo">🍔 Craving Bites</a>
            <nav class="nav-links">
                <a href="#">Home</a>
                <a href="#">Menu</a>
                <a href="#">Special Offers</a>
                <a href="#">About Us</a>
                <a href="#">Contact</a>
            </nav>
            <div class="nav-actions">
                <span class="cart-icon">🛒 Cart (0)</span>
                <button class="btn btn-primary">Order Online</button>
            </div>
        </div>
    </header>

    <!-- 2. Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Hot, Fresh, and Delivered to Your Doorstep in 20 Mins!</h1>
            <p>Satisfy your cravings with our premium smashed burgers, crispy golden fries, and thick milkshakes. Made fresh, every single day.</p>
            <div class="hero-btns">
                <button class="btn btn-primary">View Full Menu 🍔</button>
                <button class="btn btn-secondary">Find a Store Location 📍</button>
            </div>
        </div>
    </section>

    <!-- 3. Quick Categories -->
    <section class="container">
        <div class="categories-grid">
            <div class="category-card">
                <div class="category-icon">🍔</div>
                <h3>Burgers</h3>
            </div>
            <div class="category-card">
                <div class="category-icon">盒</div>
                <h3>Fried Chicken</h3>
            </div>
            <div class="category-card">
                <div class="category-icon">🍟</div>
                <h3>Sides & Fries</h3>
            </div>
            <div class="category-card">
                <div class="category-icon">🥤</div>
                <h3>Shakes & Drinks</h3>
            </div>
        </div>
    </section>

    <!-- 4. Today’s Special Offers -->
    <section class="offers">
        <div class="container">
            <h2 class="section-title">Today's <span>Special Offers</span></h2>
            <div class="offers-grid">
                <!-- Offer 1 -->
                <div class="offer-card">
                    <div>
                        <div class="offer-tag">WEEKEND EXCLUSIVE</div>
                        <h3>🔥 The Weekend Feast Combo</h3>
                        <p>2 Smashed Burgers, 1 Large Fries, 2 Milkshakes.</p>
                    </div>
                    <div class="offer-meta">
                        <div class="price"><span class="old-price">$25</span>$17.99</div>
                        <button class="btn btn-primary">Add to Cart</button>
                    </div>
                </div>
                <!-- Offer 2 -->
                <div class="offer-card">
                    <div>
                        <div class="offer-tag">MID-WEEK CRUNCH</div>
                        <h3>🍗 Crispy Wings Wednesday</h3>
                        <p>Buy 10 Hot Wings, Get 5 FREE!</p>
                    </div>
                    <div class="offer-meta">
                        <div class="price">$11.99</div>
                        <button class="btn btn-primary">Claim Offer</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. Our Fan Favorites -->
    <section class="container">
        <h2 class="section-title">Our <span>Fan Favorites</span></h2>
        <div class="favorites-grid">
            <!-- Item 1 -->
            <div class="product-card">
                <div class="product-img" style="background-image: url('https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=600&auto=format&fit=crop');"></div>
                <div class="product-info">
                    <div class="product-rating">⭐ 4.9 <span>(120+ reviews)</span></div>
                    <h3>Classic Monster Cheese</h3>
                    <p>Double beef patty, cheddar, secret sauce.</p>
                    <div class="product-action">
                        <span class="price">$8.99</span>
                        <button class="btn btn-primary">Add to Cart</button>
                    </div>
                </div>
            </div>
            <!-- Item 2 -->
            <div class="product-card">
                <div class="product-img" style="background-image: url('https://images.unsplash.com/photo-1573080496219-bb080dd4f877?q=80&w=600&auto=format&fit=crop');"></div>
                <div class="product-info">
                    <div class="product-rating">⭐ 4.8 <span>(95+ reviews)</span></div>
                    <h3>Peri-Peri Loaded Fries</h3>
                    <p>Crispy fries smothered in cheese sauce and spicy peri-peri dust.</p>
                    <div class="product-action">
                        <span class="price">$5.49</span>
                        <button class="btn btn-primary">Add to Cart</button>
                    </div>
                </div>
            </div>
            <!-- Item 3 -->
            <div class="product-card">
                <div class="product-img" style="background-image: url('https://images.unsplash.com/photo-1572490122747-3968b75cc699?q=80&w=600&auto=format&fit=crop');"></div>
                <div class="product-info">
                    <div class="product-rating">⭐ 5.0 <span>(200+ reviews)</span></div>
                    <h3>Choco-Fudge Volcano Shake</h3>
                    <p>Thick chocolate milkshake with brownie chunks.</p>
                    <div class="product-action">
                        <span class="price">$4.99</span>
                        <button class="btn btn-primary">Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. Why Choose Us? -->
    <section class="why-us">
        <div class="container">
            <h2 class="section-title">Why <span>Choose Us?</span></h2>
            <div class="props-grid">
                <div class="prop-card">
                    <div class="prop-icon">⚡</div>
                    <h3>Lightning Fast Delivery</h3>
                    <p>Hot food delivered in under 30 minutes, or it's free.</p>
                </div>
                <div class="prop-card">
                    <div class="prop-icon">🌱</div>
                    <h3>100% Fresh Ingredients</h3>
                    <p>Locally sourced veggies and premium quality meat.</p>
                </div>
                <div class="prop-card">
                    <div class="prop-icon">🧼</div>
                    <h3>Hygiene First</h3>
                    <p>Safety certified kitchen with zero compromise on cleanliness.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 7. Customer Reviews -->
    <section class="container reviews">
        <h2 class="section-title">What Our <span>Customers Say</span></h2>
        <div class="testimonial-container">
            <p class="testimonial-text">"The best burger I've had in years. The delivery was so fast the cheese was still melting when it arrived! Highly recommended."</p>
            <div class="testimonial-author">— Sarah M.</div>
            <div class="stars">⭐⭐⭐⭐⭐</div>
        </div>
    </section>

    <!-- 8. Footer -->
    <footer>
        <div class="container" style="padding: 0 0 40px 0;">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Franchise Inquiries</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Follow Us</h4>
                    <div class="social-icons">
                        <a href="#">📸 Instagram</a><br>
                        <a href="#">🎥 TikTok</a><br>
                        <a href="#">📘 Facebook</a>
                    </div>
                </div>
                <div class="footer-col" style="grid-column: span 2;">
                    <h4>Join the Crunch Club</h4>
                    <p style="color: var(--text-muted);">Join the Crunch Club for 10% off your first order!</p>
                    <form class="newsletter-form" onsubmit="event.preventDefault();">
                        <input type="email" placeholder="Enter Email" required>
                        <button type="submit" class="btn btn-primary">Subscribe</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2026 Craving Bites. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>
