        </table>
    </section>

    <!-- FAN FAVORITES SECTION -->
    <section class="section">
        <h2 class="section-title">Fan Favorites</h2>
        <div class="menu-grid">
            
            <!-- Item 1 -->
            <div class="menu-card">
                <div class="menu-img" style="background-image: url('https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=500&auto=format&fit=crop');"></div>
                <div class="menu-info">
                    <h3>The Outlaw Smash</h3>
                    <p>Two smashed Angus patties, gooey cheddar, crispy onion rings, and signature smoky Outlaw sauce.</p>
                    <div class="menu-footer">
                        <span class="price">$9.49</span>
                        <button class="btn btn-sm">Add to Bag</button>
                    </div>
                </div>
            </div>

            <!-- Item 2 -->
            <div class="menu-card">
                <div class="menu-img" style="background-image: url('https://images.unsplash.com/photo-1626082927389-6cd097cdc6ec?q=80&w=500&auto=format&fit=crop');"></div>
                <div class="menu-info">
                    <h3>Blazin' Hot Chook</h3>
                    <p>Crispy buttermilk fried chicken breast dipped in Nashville hot glaze, topped with creamy slaw and pickles.</p>
                    <div class="menu-footer">
