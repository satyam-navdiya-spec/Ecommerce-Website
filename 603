                    </div>
                </div>
            </div>

            <!-- Item 3 -->
            <div class="menu-card">
                <div class="menu-img" style="background-image: url('https://images.unsplash.com/photo-1573080496219-bb080dd4f877?q=80&w=500&auto=format&fit=crop');"></div>
                <div class="menu-info">
                    <h3>Loaded Truffle Fries</h3>
                    <p>Golden-crisp fries smothered in warm cheese sauce, real bacon bits, and a drizzle of white truffle aioli.</p>
                    <div class="menu-footer">
                        <span class="price">$5.99</span>
                        <button class="btn btn-sm">Add to Bag</button>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="footer-grid">
            <div class="footer-col">
                <h4>Our Locations</h4>
                <p><strong>Downtown:</strong> 123 Main St. (10 AM - 2 AM)</p>
                <p><strong>The Suburbs:</strong> 456 Oak Ave. (11 AM - Midnight)</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <p><a href="#" style="color: #aaa; text-decoration: none;">Track Order</a></p>
                <p><a href="#" style="color: #aaa; text-decoration: none;">Nutrition Info</a></p>
                <p><a href="#" style="color: #aaa; text-decoration: none;">Careers</a></p>
            </div>
            <div class="footer-col">
                <h4>Contact US</h4>
                <p>Phone: 1-800-CRUNCH</p>
                <p>Email: support@crunchfactor.com</p>
            </div>
        </div>
        <div class="copyright">
            &copy; 2026 The Crunch Factor Inc. | Fresh. Fast. Flavorful.
        </div>
    </footer>

</body>
</html>
