<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Crunch Factor | Fresh. Fast. Flavorful.</title>
    <style>
        /* --- RESET & VARIABLES --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        :root {
            --primary: #FF3838;
            --secondary: #FFB300;
            --dark: #1A1A1A;
            --light: #FAFAFA;
            --gray: #666;
        }

        body {
            background-color: var(--light);
            color: var(--dark);
            line-height: 1.6;
        }

        /* --- NAVIGATION --- */
        header {
            background-color: var(--dark);
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .logo {
            color: var(--secondary);
            font-size: 1.8rem;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .logo span {
            color: var(--primary);
        }
        nav a {
            color: white;
            text-decoration: none;
            margin-left: 2rem;
            font-weight: 600;
            transition: color 0.3s;
        }
        nav a:hover, nav a.active {
            color: var(--secondary);
        }

        /* --- HERO SECTION --- */
        .hero {
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=1500&auto=format&fit=crop') no-repeat center center/cover;
            height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
            padding: 0 1rem;
        }
        .hero h1 {
            font-size: 4rem;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            letter-spacing: 2px;
        }
        .hero h1 span {
            color: var(--secondary);
        }
        .hero p {
            font-size: 1.5rem;
            margin-bottom: 2rem;
            font-style: italic;
        }
        .btn {
            background-color: var(--primary);
            color: white;
            padding: 0.8rem 2.5rem;
            border: none;
            border-radius: 5px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.3s, transform 0.2s;
        }
        .btn:hover {
            background-color: #e02424;
            transform: translateY(-2px);
        }

        /* --- DEALS SECTION --- */
        .section {
            padding: 5rem 10%;
            text-align: center;
        }
        .section-title {
            font-size: 2.5rem;
            margin-bottom: 3rem;
            position: relative;
            text-transform: uppercase;
        }
        .section-title::after {
            content: '';
            display: block;
            width: 80px;
            height: 4px;
            background-color: var(--primary);
            margin: 0.5rem auto 0;
        }
        .deals-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border-radius: 8px;
            overflow: hidden;
            margin-top: 1rem;
        }
        .deals-table th, .deals-table td {
            padding: 1.2rem;
            text-align: left;
        }
        .deals-table th {
            background-color: var(--dark);
            color: white;
            text-transform: uppercase;
        }
        .deals-table tr:nth-child(even) {
            background-color: #f2f2f2;
        }
        .price {
            color: var(--primary);
            font-weight: bold;
            font-size: 1.2rem;
        }

        /* --- MENU HIGHLIGHTS --- */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2.5rem;
        }
        .menu-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            transition: transform 0.3s;
        }
        .menu-card:hover {
            transform: translateY(-5px);
        }
        .menu-img {
            height: 220px;
            background-size: cover;
            background-position: center;
        }
        .menu-info {
            padding: 1.5rem;
            text-align: left;
        }
        .menu-info h3 {
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
        }
        .menu-info p {
            color: var(--gray);
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }
        .menu-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .btn-sm {
            padding: 0.4rem 1rem;
            font-size: 0.9rem;
            background-color: var(--secondary);
            color: var(--dark);
        }
        .btn-sm:hover {
            background-color: #e5a100;
        }

        /* --- FOOTER --- */
        footer {
            background-color: var(--dark);
            color: #aaa;
            padding: 3rem 5% 1rem;
            text-align: center;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            text-align: left;
            margin-bottom: 2rem;
        }
        .footer-col h4 {
            color: white;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }
        .footer-col p {
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        .copyright {
            border-top: 1px solid #333;
            padding-top: 1.5rem;
            font-size: 0.85rem;
        }

        /* --- RESPONSIVE --- */
        @media (max-width: 768px) {
            header { flex-direction: column; gap: 1rem; }
            nav a { margin: 0 1rem; }
            .hero h1 { font-size: 2.5rem; }
            .deals-table th, .deals-table td { padding: 0.8rem; font-size: 0.9rem; }
        }
    </style>
</head>
<body>

    <!-- NAV BAR -->
    <header>
        <div class="logo">Crunch<span>Factor</span></div>
        <nav>
            <a href="#" class="active">Home</a>
            <a href="#">Menu</a>
            <a href="#">Deals</a>
            <a href="#">Locations</a>
        </nav>
    </header>

    <!-- HERO SECTION -->
