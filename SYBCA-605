<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BiteCraft Burgers | Crave the Crunch</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>
</head>
<body class="bg-amber-50 text-gray-800">

    <!-- Header / Navigation -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="text-2xl font-extrabold text-red-600 tracking-wide">
                Bite<span class="text-amber-500">Craft</span>
            </a>
            <nav class="hidden md:flex space-x-8 font-semibold text-gray-600">
                <a href="#" class="hover:text-red-600 transition">Home</a>
                <a href="#menu" class="hover:text-red-600 transition">Menu</a>
                <a href="#about" class="hover:text-red-600 transition">Our Story</a>
                <a href="#contact" class="hover:text-red-600 transition">Contact</a>
            </nav>
            <a href="#menu" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-5 rounded-full transition shadow-md">
                Order Now
            </a>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="container mx-auto px-6 py-16 md:py-24 flex flex-col md:flex-row items-center justify-between gap-12">
        <div class="max-w-xl space-y-6 text-center md:text-left">
            <span class="bg-amber-100 text-amber-800 font-bold px-4 py-1.5 rounded-full text-sm uppercase tracking-wider">
                Satisfy Your Cravings
            </span>
            <h1 class="text-4xl md:text-6xl font-black text-gray-900 leading-tight">
                Where Every Bite is a <span class="text-red-600">Masterpiece</span>
            </h1>
            <p class="text-lg text-gray-600 leading-relaxed">
                Smashed patties, secret sauces, and the crispiest fries in town. Made fresh, served fast, and crafted just the way you like it.
            </p>
            <div class="flex flex-col sm:flex-row justify-center md:justify-start gap-4 pt-4">
                <a href="#menu" class="bg-amber-500 hover:bg-amber-600 text-white font-extrabold py-4 px-8 rounded-xl text-center shadow-lg transition transform hover:-translate-y-1">
                    Explore Menu
                </a>
                <a href="#about" class="bg-white hover:bg-gray-100 text-gray-800 font-extrabold py-4 px-8 rounded-xl text-center shadow-md border border-gray-200 transition transform hover:-translate-y-1">
                    Learn More
                </a>
            </div>
        </div>
        <!-- Placeholder for a high-quality food image -->
        <div class="w-full md:w-1/2 flex justify-center">
            <div class="relative w-72 h-72 sm:w-96 sm:h-96 bg-amber-400 rounded-full flex items-center justify-center shadow-2xl overflow-hidden">
                <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=600&q=80" 
                     alt="Delicious Burger" 
                     class="w-5/6 h-5/6 object-cover rounded-2xl rotate-3 hover:rotate-0 transition duration-300">
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="bg-white py-12 border-y border-gray-100">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div class="p-4 space-y-2">
                <div class="text-3xl">🔥</div>
                <h3 class="font-bold text-xl text-gray-900">100% Fresh Beef</h3>
                <p class="text-gray-500 text-sm">Never frozen, locally sourced patties smashed to perfection.</p>
            </div>
            <div class="p-4 space-y-2">
                <div class="text-3xl">⚡</div>
                <h3 class="font-bold text-xl text-gray-900">Lightning Fast</h3>
                <p class="text-gray-500 text-sm">Hot and ready to go in under 10 minutes, guaranteed.</p>
            </div>
            <div class="p-4 space-y-2">
                <div class="text-3xl">🛵</div>
                <h3 class="font-bold text-xl text-gray-900">Free Delivery</h3>
                <p class="text-gray-500 text-sm">On all orders over $25 straight to your doorstep.</p>
            </div>
        </div>
    </section>

    <!-- Featured Menu Section -->
    <section id="menu" class="container mx-auto px-6 py-16">
        <div class="text-center max-w-xl mx-auto mb-12 space-y-3">
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900">Fan Favorites</h2>
            <p class="text-gray-600">You can't go wrong with these crowd-pleasing classics.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Item 1 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition flex flex-col">
                <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=500&q=80" alt="Classic Cheeseburger" class="h-48 w-full object-cover">
                <div class="p-6 flex flex-col flex-grow justify-between space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="font-bold text-xl text-gray-900">Classic Craft Burger</h3>
                            <span class="text-red-600 font-extrabold text-lg">$8.99</span>
                        </div>
                        <p class="text-gray-500 text-sm leading-relaxed">Smashed beef patty, cheddar cheese, pickles, and our signature craft sauce on a brioche bun.</p>
                    </div>
                    <button class="w-full bg-gray-900 hover:bg-red-600 text-white font-bold py-2.5 rounded-xl transition text-sm">Add to Order</button>
                </div>
            </div>

            <!-- Item 2 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition flex flex-col">
                <img src="https://images.unsplash.com/photo-1625813506062-0aeb1d7a094b?auto=format&fit=crop&w=500&q=80" alt="Loaded Fries" class="h-48 w-full object-cover">
                <div class="p-6 flex flex-col flex-grow justify-between space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="font-bold text-xl text-gray-900">Bacon Loaded Fries</h3>
                            <span class="text-red-600 font-extrabold text-lg">$6.49</span>
                        </div>
                        <p class="text-gray-500 text-sm leading-relaxed">Crispy golden fries smothered in melted cheese sauce, crispy bacon bits, and chives.</p>
                    </div>
                    <button class="w-full bg-gray-900 hover:bg-red-600 text-white font-bold py-2.5 rounded-xl transition text-sm">Add to Order</button>
                </div>
            </div>

            <!-- Item 3 -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition flex flex-col">
                <img src="https://images.unsplash.com/photo-1610614819513-58e34989848b?auto=format&fit=crop&w=500&q=80" alt="Crispy Chicken Tenders" class="h-48 w-full object-cover">
                <div class="p-6 flex flex-col flex-grow justify-between space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="font-bold text-xl text-gray-900">Nashville Hot Tenders</h3>
                            <span class="text-red-600 font-extrabold text-lg">$9.29</span>
                        </div>
                        <p class="text-gray-500 text-sm leading-relaxed">Four pieces of ultra-crispy chicken tenders tossed in fiery Nashville spice mix with honey drizzle.</p>
                    </div>
                    <button class="w-full bg-gray-900 hover:bg-red-600 text-white font-bold py-2.5 rounded-xl transition text-sm">Add to Order</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer id="contact" class="bg-gray-900 text-gray-400 py-12 mt-12">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 border-b border-gray-800 pb-8">
            <div class="space-y-3">
                <h3 class="text-white text-xl font-bold">BiteCraft Burgers</h3>
                <p class="text-sm">Fresh ingredients, bold flavors, fast service. Your neighborhood favorite spot.</p>
            </div>
            <div class="space-y-2">
                <h4 class="text-white font-semibold">Hours of Operation</h4>
                <p class="text-sm">Mon - Thu: 11:00 AM - 10:00 PM</p>
                <p class="text-sm">Fri - Sun: 11:00 AM - Midnight</p>
            </div>
            <div class="space-y-2">
                <h4 class="text-white font-semibold">Find Us</h4>
                <p class="text-sm">📍 123 Flavor Avenue, Foodie City</p>
                <p class="text-sm">📞 (555) 123-4567</p>
            </div>
        </div>
        <div class="container mx-auto px-6 pt-6 text-center text-xs">
            &copy; 2026 BiteCraft Burgers. All rights reserved.
        </div>
    </footer>

</body>
</html>
