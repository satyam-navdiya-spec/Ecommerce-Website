<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FastFood Shop</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #fff7f0;
      color: #222;
      line-height: 1.6;
    }

    header {
      background: linear-gradient(135deg, #ff6b35, #ff9f1c);
      color: white;
      padding: 20px 8%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .logo {
      font-size: 28px;
      font-weight: bold;
    }

    nav a {
      color: white;
      text-decoration: none;
      margin-left: 20px;
      font-weight: 600;
    }

    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 80px 8%;
      gap: 40px;
      flex-wrap: wrap;
      background: #fff;
    }

    .hero-text {
      flex: 1;
      min-width: 280px;
    }

    .hero-text h1 {
      font-size: 56px;
      color: #ff6b35;
      margin-bottom: 20px;
      line-height: 1.1;
    }

    .hero-text p {
      font-size: 18px;
      margin-bottom: 25px;
      color: #555;
      max-width: 550px;
    }

    .btn {
      display: inline-block;
      padding: 14px 28px;
      background: #ff6b35;
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      background: #e85a2b;
    }

    .hero-image {
      flex: 1;
      min-width: 280px;
      text-align: center;
    }

    .hero-image img {
      max-width: 100%;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    section {
      padding: 70px 8%;
    }

    .section-title {
      text-align: center;
      font-size: 36px;
      color: #ff6b35;
      margin-bottom: 40px;
    }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 25px;
    }

    .card {
      background: white;
      border-radius: 16px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      border-radius: 12px;
      margin-bottom: 15px;
    }

    .card h3 {
      margin-bottom: 10px;
      color: #222;
    }

    .card p {
      color: #666;
      margin-bottom: 10px;
    }

    .price {
      font-weight: bold;
      color: #ff6b35;
      font-size: 20px;
    }

    .offers {
      background: #ffefe6;
      text-align: center;
      border-top: 4px solid #ff6b35;
      border-bottom: 4px solid #ff6b35;
    }

    .offers p {
      font-size: 20px;
      color: #333;
    }

    footer {
      background: #222;
      color: white;
      text-align: center;
      padding: 25px;
    }

    @media (max-width: 768px) {
      header {
        flex-direction: column;
        gap: 10px;
      }

      .hero-text h1 {
        font-size: 40px;
      }

      nav a {
        margin: 0 10px;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo">FastFood Shop</div>
    <nav>
      <a href="#home">Home</a>
      <a href="#menu">Menu</a>
      <a href="#offers">Offers</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero" id="home">
    <div class="hero-text">
      <h1>Delicious Fast Food, Served Fresh!</h1>
      <p>Enjoy burgers, fries, pizzas, wraps, and more at your favorite fast food shop. Tasty meals, quick delivery, and unbeatable prices.</p>
      <a href="#menu" class="btn">Order Now</a>
    </div>
    <div class="hero-image">
      <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=900&q=80" alt="Fast Food Burger">
    </div>
  </section>

  <section id="menu">
    <h2 class="section-title">Our Popular Menu</h2>
    <div class="menu-grid">
      <div class="card">
        <img src="https://images.unsplash.com/photo-1561758033-d89a9ad46330?auto=format&fit=crop&w=900&q=80" alt="Burger">
        <h3>Classic Burger</h3>
        <p>Juicy beef patty with cheese and fresh veggies.</p>
        <div class="price">$8.99</div>
      </div>
      <div class="card">
        <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=900&q=80" alt="Pizza">
        <h3>Cheese Pizza</h3>
        <p>Loaded with mozzarella and rich tomato sauce.</p>
        <div class="price">$10.99</div>
      </div>
      <div class="card">
        <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?auto=format&fit=crop&w=900&q=80" alt="Fries">
        <h3>Crispy Fries</h3>
        <p>Golden, crispy fries served with special sauce.</p>
        <div class="price">$4.99</div>
      </div>
      <div class="card">
        <img src="https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?auto=format&fit=crop&w=900&q=80" alt="Wrap">
        <h3>Chicken Wrap</h3>
        <p>Fresh grilled chicken wrapped with veggies.</p>
        <div class="price">$7.99</div>
      </div>
    </div>
  </section>

  <section class="offers" id="offers">
    <h2 class="section-title">Special Offers</h2>
    <p>Get 20% off on your first order and free delivery on orders above $25!</p>
  </section>

  <section id="contact">
    <h2 class="section-title">Contact Us</h2>
    <div style="text-align:center; font-size:18px; color:#444;">
      <p>Email: support@fastfoodshop.com</p>
      <p>Phone: +1 234 567 890</p>
      <p>Address: 123 Food Street, City Center</p>
    </div>
  </sec
