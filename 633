<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fast Food Store</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#fff8f0;
}

header{
    background:#d62828;
    color:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 60px;
}

header h1{
    font-size:32px;
}

nav a{
    color:white;
    text-decoration:none;
    margin:0 15px;
    font-weight:bold;
}

.hero{
    height:90vh;
    display:flex;
    justify-content:space-around;
    align-items:center;
    padding:40px;
    background:linear-gradient(to right,#ffcc70,#fff8f0);
}

.hero-text h2{
    font-size:50px;
    color:#d62828;
}

.hero-text p{
    margin:20px 0;
    font-size:20px;
}

button{
    background:#d62828;
    color:white;
    padding:15px 30px;
    border:none;
    border-radius:8px;
    font-size:18px;
    cursor:pointer;
}

.hero img{
    width:450px;
    border-radius:20px;
}

.menu{
    text-align:center;
    padding:60px 20px;
}

.menu h2{
    color:#d62828;
    margin-bottom:30px;
}

.cards{
    display:flex;
    justify-content:center;
    gap:30px;
    flex-wrap:wrap;
}

.card{
    background:white;
    width:250px;
    padding:20px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

.card img{
    width:100%;
    border-radius:10px;
}

.card h3{
    margin:15px 0;
}

footer{
    background:#d62828;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:40px;
}
</style>

</head>
<body>

<header>
    <h1>🍔 Fast Bite</h1>
    <nav>
        <a href="#">Home</a>
        <a href="#">Menu</a>
        <a href="#">Offers</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <div class="hero-text">
        <h2>Fresh & Tasty Fast Food</h2>
        <p>Burgers, Pizza, Fries & Drinks delivered fast to your doorstep.</p>
        <button>Order Now</button>
    </div>

    <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=600" alt="Burger">
</section>

<section class="menu">
    <h2>Popular Menu</h2>

    <div class="cards">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=500" alt="Pizza">
            <h3>Cheese Pizza</h3>
            <p>₹299</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1550547660-d9450f859349?w=500" alt="Burger">
            <h3>Classic Burger</h3>
            <p>₹149</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1573080496219-bb080dd4f877?w=500" alt="Fries">
            <h3>French Fries</h3>
            <p>₹99</p>
        </div>

    </div>
</section>

<footer>
    © 2026 Fast Bite | Delicious Food, Fast Delivery
</footer>

</body>
</html>
