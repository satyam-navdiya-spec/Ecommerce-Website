<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIZZLE & SNAP | Fresh. Fast. Flavorful.</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Poppins', sans-serif; }
    </style>
</head>
<body class="bg-amber-50 text-neutral-800">

    <!-- 1. NAVBAR -->
    <nav class="bg-neutral-950 text-white sticky top-0 z-50 shadow-md">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="text-2xl font-extrabold tracking-wider text-orange-500">SIZZLE & SNAP</a>
            <div class="hidden md:flex space-x-8 font-semibold">
                <a href="#" class="hover:text-orange-400 transition">Home</a>
                <a href="#menu" class="hover:text-orange-400 transition">Menu</a>
                <a href="#deals" class="hover:text-orange-400 transition">Deals</a>
                <a href="#" class="hover:text-orange-400 transition">Track Order</a>
            </div>
            <button class="bg-orange-500 hover:bg-orange-600 font-bold px-5 py-2 rounded-full flex items-center gap-2 transition">
                <span>🛒</span> Cart <span class="bg-white text-orange-600 text-xs rounded-full px-2 py-0.5 ml-1">0</span>
            </button>
        </div>
    </nav>

    <!-- 2. HERO SECTION -->
    <header class="bg-neutral-900 text-white py-20 px-6 text-center bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-neutral-800 via-neutral-950 to-neutral-950">
        <div class="max-w-3xl mx-auto">
            <span class="bg-orange-500/20 text-orange-400 text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-wider">🔥 Limited Offer</span>
            <h1 class="text-4xl md:text-6xl font-extrabold my-6 leading-tight">The Ultimate Burger Experience, Delivered in 20 Mins.</h1>
            <p class="text-neutral-400 md:text-lg mb-8 max-w-xl mx-auto">100% Flame-Grilled Angus Beef. Melted Cheddar. Secret House Sauce. Pure Bliss.</p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="#menu" class="bg-orange-500 hover:bg-orange-600 font-bold text-lg px-8 py-4 rounded-xl transition shadow-lg shadow-orange-500/20">🛍️ ORDER NOW</a>
                <a href="#menu" class="bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 font-bold text-lg px-8 py-4 rounded-xl transition">📜 View Menu</a>
            </div>
            <p class="text-xs text-neutral-500 mt-6">🚚 Free delivery on your first order! Use code: <span class="text-orange-400 font-bold">FIRSTBITE</span></p>
        </div>
    </header>

    <!-- 3. DEALS SECTION -->
    <section id="deals" class="max-w-7xl mx-auto px-6 py-16">
        <h2 class="text-3xl font-extrabold mb-8 flex items-center gap-2 text-neutral-900">🕒 Limited-Time Deals</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Deal 1 -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-neutral-200/60 flex flex-col justify-between">
                <div>
                    <h3 class="text-xl font-bold text-neutral-900 mb-2">The Midnight Craving Combo</h3>
                    <p class="text-sm text-neutral-500 mb-4">1x Double Smash Burger + Large Fries + Bottomless Soda</p>
                </div>
                <div class="flex justify-between items-center mt-4">
                    <div>
                        <span class="text-xs line-through text-neutral-400 block">$18.00</span>
                        <span class="text-2xl font-extrabold text-orange-600">$11.99</span>
                    </div>
                    <button class="bg-neutral-900 hover:bg-neutral-800 text-white font-bold px-4 py-2 rounded-xl text-sm transition">Add to Cart</button>
                </div>
            </div>
            <!-- Deal 2 -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-neutral-200/60 flex flex-col justify-between">
                <div>
                    <h3 class="text-xl font-bold text-neutral-900 mb-2">Twin Feast Party</h3>
                    <p class="text-sm text-neutral-500 mb-4">2x Crispy Chicken Burgers + 6pcs Nuggets + 2 Drinks</p>
                </div>
                <div class="flex justify-between items-center mt-4">
                    <div>
                        <span class="text-xs line-through text-neutral-400 block">$25.00</span>
                        <span class="text-2xl font-extrabold text-orange-600">$17.50</span>
                    </div>
                    <button class="bg-neutral-900 hover:bg-neutral-800 text-white font-bold px-4 py-2 rounded-xl text-sm transition">Add to Cart</button>
                </div>
            </div>
            <!-- Deal 3 -->
            <div class="bg-orange-500 text-white p-6 rounded-2xl shadow-md flex flex-col justify-between md:col-span-2 lg:col-span-1">
                <div>
                    <span class="bg-white/20 text-xs uppercase tracking-wide px-2.5 py-1 rounded-md font-bold">Add-on</span>
                    <h3 class="text-xl font-bold mt-2 mb-1">Loaded Fries Upgrade</h3>
                    <p class="text-sm text-orange-100 mb-4">Add Cheese & Bacon to any meal's fries.</p>
                </div>
                <div class="flex justify-between items-center mt-4">
                    <span class="text-2xl font-extrabold">+$1.99</span>
                    <button class="bg-white text-orange-600 hover:bg-orange-50 font-bold px-5 py-2 rounded-xl text-sm transition shadow-md">Upgrade</button>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. FAN FAVORITES -->
    <section id="menu" class="bg-neutral-900 text-white py-16 px-6">
        <div class="max-w-7xl mx-auto">
            <h2 class="text-3xl font-extrabold mb-10 flex items-center gap-2">🍕 Fan Favorites <span class="text-sm font-normal text-neutral-400">(Best Sellers)</span></h2>
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Item 1 -->
                <div class="bg-neutral-800/50 border border-neutral-800 rounded-3xl overflow-hidden group hover:border-orange-500/50 transition duration-300">
                    <div class="h-48 bg-neutral-800 flex items-center justify-center text-5xl">🍔</div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">The Monster Smash</h3>
                        <p class="text-sm text-neutral-400 leading-relaxed mb-6">Two smashed beef patties, crispy bacon, caramelized onions, and our signature Sizzle Sauce.</p>
                        <div class="flex justify-between items-center">
                            <span class="text-2xl font-extrabold text-orange-400">$8.99</span>
                            <button class="bg-orange-500 hover:bg-orange-600 font-bold px-4 py-2 rounded-xl text-sm transition">🛒 Add</button>
                        </div>
                    </div>
                </div>
                <!-- Item 2 -->
                <div class="bg-neutral-800/50 border border-neutral-800 rounded-3xl overflow-hidden group hover:border-orange-500/50 transition duration-300">
                    <div class="h-48 bg-neutral-800 flex items-center justify-center text-5xl">🍗</div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Spicy Nashville Bird</h3>
                        <p class="text-sm text-neutral-400 leading-relaxed mb-6">Crispy fried chicken breast dipped in cayenne pepper glaze, topped with creamy slaw and pickles.</p>
                        <div class="flex justify-between items-center">
                            <span class="text-2xl font-extrabold text-orange-400">$7.49</span>
                            <button class="bg-orange-500 hover:bg-orange-600 font-bold px-4 py-2 rounded-xl text-sm transition">🛒 Add</button>
                        </div>
                    </div>
                </div>
                <!-- Item 3 -->
                <div class="bg-neutral-800/50 border border-neutral-800 rounded-3xl overflow-hidden group hover:border-orange-500/50 transition duration-300">
                    <div class="h-48 bg-neutral-800 flex items-center justify-center text-5xl">🍟</div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Garlic Parm Loaded Fries</h3>
                        <p class="text-sm text-neutral-400 leading-relaxed mb-6">Golden crinkle-cut fries smothered in garlic butter, freshly grated parmesan, and chives.</p>
                        <div class="flex justify-between items-center">
                            <span class="text-2xl font-extrabold text-orange-400">$5.29</span>
                            <button class="bg-orange-500 hover:bg-orange-600 font-bold px-4 py-2 rounded-xl text-sm transition">🛒 Add</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. WHY CHOOSE US -->
    <section class="max-w-5xl mx-auto px-6 py-16 text-center">
        <h2 class="text-3xl font-extrabold mb-12 text-neutral-900">🚀 Why Choose Us?</h2>
        <div class="grid sm:grid-cols-3 gap-8">
            <div class="p-4">
                <div class="text-4xl mb-4">🔥</div>
                <h3 class="text-lg font-bold mb-2">Always Flame-Grilled</h3>
                <p class="text-sm text-neutral-500 leading-relaxed">We don't do microwaved food. Every single patty is grilled fresh right to your order.</p>
            </div>
            <div class="p-4">
                <div class="text-4xl mb-4">⚡</div>
                <h3 class="text-lg font-bold mb-2">Lightning Fast</h3>
                <p class="text-sm text-neutral-500 leading-relaxed">If it takes longer than 25 minutes from checkout to your door, your meal is entirely <b>free</b>.</p>
            </div>
            <div class="p-4">
                <div class="text-4xl mb-4">🌿</div>
                <h3 class="text-lg font-bold mb-2">Fresh Ingredients</h3>
                <p class="text-sm text-neutral-500 leading-relaxed">Locally sourced crisp vegetables and premium signature buns baked fresh every morning.</p>
            </div>
        </div>
    </section>

    <!-- 6. TESTIMONIALS -->
    <section class="bg-amber-100/60 border-y border-amber-200/50 py-16 px-6">
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-amber-200/30">
                <p class="text-neutral-600 italic mb-4">"The Nashville Bird is legitimately the best chicken sandwich in town. It actually stays crispy when delivered!"</p>
                <span class="text-sm font-bold text-neutral-800">— Sarah M.</span>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-amber-200/30">
                <p class="text-neutral-600 italic mb-4">"Twenty minutes flat. The cheese was still perfectly melted. 10/10 will order again tonight."</p>
                <span class="text-sm font-bold text-neutral-800">— David K.</span>
            </div>
        </div>
    </section>

    <!-- 7. NEWSLETTER -->
    <section class="max-w-4xl mx-auto px-6 py-16 text-center">
        <div class="bg-neutral-950 text-white rounded-3xl p-8 md:p-12 shadow-xl">
            <h2 class="text-2xl md:text-3xl font-extrabold mb-2">📥 Join The Crunch Club</h2>
            <p class="text-neutral-400 text-sm md:text-base mb-6 max-w-md mx-auto">Get <b>15% OFF</b> your next order and exclusive access to secret menu drops.</p>
            <form class="flex flex-col sm:flex-row max-w-md mx-auto gap-3">
                <input type="email" placeholder="Enter your email address" class="bg-neutral-800 border border-neutral-700 text-white rounded-xl px-4 py-3 flex-grow text-sm focus:outline-none focus:border-orange-500">
                <button type="submit" class="bg-orange-500 hover:bg-orange-600 font-bold px-6 py-3 rounded-xl text-sm transition whitespace-nowrap">📩 Get My 15% Off</button>
            </form>
        </div>
    </section>

    <!-- 8. FOOTER -->
    <footer class="bg-neutral-950 text-neutral-500 text-sm py-12 px-6 border-t border-neutral-900">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-center md:text-left">
                <p class="font-bold text-white mb-1">📍 Find us: <span class="font-normal text-neutral-400">123 Flavor Avenue, Food District</span></p>
                <p class="font-bold text-white">⏰ Hours: <span class="font-normal text-neutral-400">Open daily from 11:00 AM – 3:00 AM</span></p>
            </div>
            <div class="flex space-x-6">
                <a href="#" class="hover:text-white transition">Instagram</a>
                <a href="#" class="hover:text-white transition">TikTok</a>
                <a href="#" class="hover:text-white transition">Facebook</a>
            </div>
            <p class="text-xs">&copy; 2026 Sizzle & Snap Inc. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>
