<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Sizzle Shack | Fresh & Fast Burgers</title>
    <style>
        /* --- Reset & Base Styles --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f9f9f9;
            color: #333;
            line-height: 1.6;
        }

        /* --- Theme Variables --- */
        :root {
            --primary-color: #ff4757; /* Spicy Red */
            --secondary-color: #ffa502; /* Golden Yellow */
            --dark-color: #2f3542;
            --light-color: #ffffff;
        }

        /* --- Header / Navigation --- */
        header {
            background-color: var(--dark-color);
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            color: var(--secondary-color);
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--light-color);
        }

        nav a {
            color: var(--light-color);
            text-decoration: none;
            margin-left: 20px;
            font-weight: 600;
            transition: color 0.3s;
        }

        nav a:hover {
            color: var(--primary-color);
        }

        /* --- Hero Section --- */
        .hero {
            background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=1200') no-repeat center center/cover;
            height: 70vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: var(--light-color);
            padding: 20px;
        }

        .hero h1 {
            font-size: 48px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .hero p {
            font-size: 20px;
            margin-bottom: 30px;
            max-width: 600px;
        }

        .btn {
            background-color: var(--primary-color);
            color: var(--light-color);
            padding: 12px 30px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 25px;
            transition: transform 0.2s, background-color 0.3s;
        }

        .btn:hover {
            background-color: #e03d4f;
            transform: scale(1.05);
        }

        /* --- Features Section --- */
        .features {
            display: flex;
            justify-content: space-around;
            background-color: var(--secondary-color);
            padding: 40px 20px;
            text-align: center;
        }

        .feature-item {
            flex: 1;
            max-width: 300px;
            color: var(--dark-color);
            padding: 10px;
        }

        .feature-item h3 {
            font-size: 20px;
            margin-bottom: 5px;
        }

        /* --- Menu Highlights --- */
        .menu-highlights {
            padding: 60px 20px;
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .menu-highlights h2 {
            font-size: 36px;
            margin-bottom: 40px;
            color: var(--dark-color);
            position: relative;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .menu-card {
            background-color: var(--light-color);
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .menu-card:hover {
            transform: translateY(-5px);
        }

        .menu-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .menu-info {
            padding: 20px;
        }

        .menu-info h3 {
            margin-bottom: 10px;
            font-size: 22px;
        }

        .menu-info p {
            color: #777;
            font-size: 14px;
            margin-bottom: 15px;
            height: 42px;
            overflow: hidden;
        }

        .price {
            font-size: 20px;
            font-weight: bold;
            color: var(--primary-color);
        }

        /* --- Footer --- */
        footer {
            background-color: var(--dark-color);
            color: #a4b0be;
            text-align: center;
            padding: 40px 20px;
            font-size: 14px;
        }

        footer p {
            margin-bottom: 10px;
        }

        .footer-info {
            color: var(--light-color);
            margin-top: 15px;
        }

        /* --- Responsive Design --- */
        @media (max-width: 768px) {
            header {
                flex-direction: column;
                padding: 15px;
            }
            nav {
                margin-top: 15px;
            }
            .hero h1 {
                font-size: 32px;
            }
            .features {
                flex-direction: column;
                align-items: center;
                gap: 20px;
            }
        }
    </style>
</head>
<body>

    <!-- Header / Nav -->
    <header>
        <div class="logo">Sizzle<span>Shack</span></div>
        <nav>
            <a href="#">Home</a>
            <a href="#">Menu</a>
            <a href="#">About</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <h1>Craving Something Epic?</h1>
        <p>Fresh ingredients meet fast, flame-grilled perfection. Smashed to order, just the way you like it.</p>
        <a href="#" class="btn">Order Online Now</a>
    </section>

    <!-- Features Ribbon -->
    <section class="features">
        <div class="feature-item">
            <h3>100% Fresh Beef</h3>
            <p>Never frozen patties smashed to crispy perfection.</p>
        </div>
        <div class="feature-item">
            <h3>Locally Sourced</h3>
            <p>Fresh buns and veggies delivered every single morning.</p>
        </div>
        <div class="feature-item">
            <h3>Lightning Fast</h3>
            <p>From the grill to your hands in under 5 minutes.</p>
        </div>
    </section>

    <!-- Menu Highlights -->
    <section class="menu-highlights">
        <h2>Today's Headliners</h2>
        <div class="menu-grid">
            <!-- Item 1 -->
            <div class="menu-card">
                <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=500" alt="Monster Crunch Burger" class="menu-img">
                <div class="menu-info">
                    <h3>The Monster Crunch</h3>
                    <p>Double beef patty, crispy onion rings, cheddar, and our secret Shack Sauce.</p>
                    <div class="price">$8.99</div>
                </div>
            </div>
            <!-- Item 2 -->
            <div class="menu-card">
                <img src="https://images.unsplash.com/photo-1573080496219-bb080dd4f877?q=80&w=500" alt="Truffle Parm Fries" class="menu-img">
                <div class="menu-info">
                    <h3>Truffle Parm Fries</h3>
                    <p>Golden, crispy thin-cut fries tossed in aromatic truffle oil and fresh parmesan.</p>
                    <div class="price">$4.50</div>
                </div>
            </div>
            <!-- Item 3 -->
            <div class="menu-card">
                <img src="https://images.unsplash.com/photo-1572490122747-3968b75cc699?q=80&w=500" alt="Salted Caramel Shake" class="menu-img">
                <div class="menu-info">
                    <h3>Salted Caramel Shake</h3>
                    <p>Thick, creamy vanilla soft serve spun with rich sea-salt caramel and whipped cream.</p>
                    <div class="price">$3.99</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 The Sizzle Shack Inc. All rights reserved. Built with love and extra cheese.</p>
        <div class="footer-info">
            <p><strong>Address:</strong> 123 Flavor Avenue, Downtown</p>
            <p><strong>Hours:</strong> Mon - Sun: 10:00 AM - Midnight (Drive-Thru open until 2:00 AM)</p>
        </div>
    </footer>

</body>
</html>
